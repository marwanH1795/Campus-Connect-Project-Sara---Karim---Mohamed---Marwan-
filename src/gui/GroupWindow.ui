      border-radius: 12px;
      padding: 8px;
      font-size: 12px;
      font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    }

    QScrollBar:vertical {
      background: #1e1f2e;
      width: 8px;
      border-radius: 4px;
    }
    QScrollBar::handle:vertical {
      background: #4a4b6a;
      border-radius: 4px;
      min-height: 20px;
    }
    QScrollBar::handle:vertical:hover {
      background: #7c6af7;
    }
    QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
