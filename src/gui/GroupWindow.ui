  <widget class="QTextEdit" name="groupDisplay">
   <property name="geometry">
    <rect><x>30</x><y>116</y><width>600</width><height>200</height></rect>
   </property>
   <property name="html">
    <string>&lt;!DOCTYPE HTML&gt;&lt;html&gt;&lt;body style="font-family:'Segoe UI'; font-size:12pt; color:#9a9ac0;"&gt;
    &lt;p style="margin:6px 0;"&gt;&lt;i&gt;Group messages will appear here…&lt;/i&gt;&lt;/p&gt;
    &lt;/body&gt;&lt;/html&gt;</string>
   </property>
   <property name="readOnly">
    <bool>true</bool>
