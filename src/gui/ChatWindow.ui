  <property name="styleSheet">
   <string notr="true">
QWidget#ChatWindow {
    font-family: 'Segoe UI', Arial, sans-serif;
    color: #e0e0f0;
    background-color: #1e1f2e;
}

/* ── Chat display ── */
QTextEdit {
    background-color: #16172a;
    border: 2px solid #3a3b55;
    border-radius: 12px;
    padding: 12px;
    font-size: 13px;
    font-family: 'Segoe UI', Arial, sans-serif;
    color: #dcdcf0;
}

/* ── Message input ── */
QLineEdit {
    background-color: #2a2b3d;
    color: #e0e0f0;
    border: 2px solid #4a4b6a;
    border-radius: 10px;
    padding: 4px 14px;
    font-size: 13px;
    font-family: 'Segoe UI', Arial, sans-serif;
}
QLineEdit:focus {
    border: 2px solid #7c6af7;
}
QLineEdit[placeholderText] {
    color: #9a9ac0;
}

/* ── Send button ── */
QPushButton#sendButton {
    background-color: #3ecf8e;
    color: #1e1f2e;
    border: none;
    border-radius: 10px;
    font-size: 13px;
    font-weight: bold;
    font-family: 'Segoe UI', Arial, sans-serif;
}
QPushButton#sendButton:hover {
    background-color: #55e0a3;
}
QPushButton#sendButton:pressed {
    background-color: #28a570;
}

/* ── Groups button ── */
QPushButton#groupButton {
    background-color: #2a2b3d;
    color: #7c6af7;
    border: 2px solid #7c6af7;
    border-radius: 10px;
    font-size: 13px;
    font-weight: bold;
    font-family: 'Segoe UI', Arial, sans-serif;
}
QPushButton#groupButton:hover {
    background-color: #7c6af7;
    color: #ffffff;
}
QPushButton#groupButton:pressed {
    background-color: #5a4fcf;
    color: #ffffff;
}

/* ── Scrollbars ── */
QScrollBar:vertical {
    background: #1e1f2e;
    width: 8px;
    border-radius: 4px;
}
QScrollBar::handle:vertical {
    background: #4a4b6a;
    border-radius: 4px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover {
    background: #7c6af7;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}
   </string>
